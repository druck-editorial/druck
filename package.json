{
  "name": "druck-workspace",
  "private": true,
  "author": "Artem Iagovdik <artyom.yagovdik@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --filter @druck-editorial/app dev",
    "build": "pnpm --filter @druck-editorial/app build",
    "engine:build": "pnpm --filter @druck-editorial/engine build",
    "widget:build": "pnpm --filter @druck-editorial/widget build",
    "analytics:build": "pnpm --filter @druck-editorial/analytics build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "check:links": "node scripts/check-links.mjs"
  }
}