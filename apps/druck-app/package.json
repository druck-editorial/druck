{
  "name": "@druck-editorial/app",
  "version": "0.1.0",
  "private": true,
  "author": "Artem Iagovdik <artyom.yagovdik@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node prerender/fetch-snapshot.mjs && cp ../../packages/druck-css/feed.css public/feed.css && cp src/styles/fonts.css public/fonts.css && pnpm --filter @druck-editorial/engine build && pnpm --filter @druck-editorial/widget build && pnpm --filter @druck-editorial/analytics build && tsc --noEmit && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "audit": "node scripts/audit.mjs",
    "build:druck": "pnpm build && DRUCK_BASE=/druck/ node scripts/apply-base.mjs",
    "deploy:druck": "pnpm build:druck && rsync -az --delete -e ssh dist/ wolton:/root/workspaces/sonto-news/_site/druck/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@druck-editorial/analytics": "workspace:*",
    "@druck-editorial/css": "workspace:*",
    "@druck-editorial/engine": "workspace:*",
    "@druck-editorial/widget": "workspace:*"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^3.2.0",
    "happy-dom": "^17.0.0",
    "lighthouse": "^13.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}