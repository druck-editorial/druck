{
  "name": "@druck/app",
  "version": "0.1.0",
  "private": true,
  "author": "Artem Iagovdik <artyom.yagovdik@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @druck/engine build && pnpm --filter @druck/widget build && tsc && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@druck/engine": "workspace:*",
    "@druck/css": "workspace:*",
    "@druck/analytics": "workspace:*",
    "preact": "^10.26.0",
    "@preact/signals": "^2.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0",
    "happy-dom": "^17.0.0"
  }
}