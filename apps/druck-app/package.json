{
  "name": "@druck/app",
  "version": "0.1.0",
  "private": true,
  "author": "Artem Iagovdik <artyom.yagovdik@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @druck/engine build && pnpm --filter @druck/widget build && tsc && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@druck/analytics": "workspace:*",
    "@druck/css": "workspace:*",
    "@druck/engine": "workspace:*",
    "@druck/widget": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.2.0",
    "happy-dom": "^17.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
