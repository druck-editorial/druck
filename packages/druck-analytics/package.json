{
  "name": "@druck-editorial/analytics",
  "version": "0.1.0",
  "description": "Local-first reading analytics for druck pages: depth, active time, chapters.",
  "author": "Artem Iagovdik <artyom.yagovdik@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/druck-editorial/druck.git",
    "directory": "packages/druck-analytics"
  },
  "homepage": "https://github.com/druck-editorial/druck",
  "keywords": ["editorial", "typography", "rendering", "magazine", "web-components"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
